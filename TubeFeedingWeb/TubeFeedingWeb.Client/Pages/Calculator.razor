@page "/calculator"
@rendermode InteractiveAuto

<PageTitle>Calculator</PageTitle>

<div class="main">

    <h1>Calculator</h1>

    @if (calculated == false)
    {
        <ul>
            <li><input @bind="newPatientName" /></li>
            <li><input type="radio" @bind="newSpecies" /> <label for="cat">Cat</label> <label for="dog">Dog</label></li>
            <li><input @bind="newBodyWeight" /></li>
            <li><input @bind="newDietName" /></li>
            <li><input @bind="newKcalPerG" /></li>
            <li><input @bind="newDietNetWeight" /></li>
            <li><input @bind="newDietWaterPercentage" /></li>
            <li><input @bind="newDays" /></li>
            <li><button @onclick="Calculate">Calculate</button></li>
        </ul>
    }

    @if (calculated == true)
    {
        <button @onclick="Reset">Reset</button>

        @for (int i = 0; i < data.Days; i++)
        {

        }
            
        <table class="calculations">
            <tr>
                <td>Patient name:</td>
                <td>@data.PatientName</td>
            </tr>
            <tr>
                <td>Species:</td>
                <td>@data.Species</td>
            </tr>
            <tr>
                <td>Bodyweight:</td>
                <td>@data.BodyWeight kg</td>
            </tr>
            <tr>
                <td>Name of the diet to be fed:</td>
                <td>@data.DietName</td>
            </tr>
            <tr>
                <td>The diet's kcal/g:</td>
                <td>@data.KcalPerG</td>
            </tr>
            <tr>
                <td>Net weight of diet per container:</td>
                <td>@data.DietNetWeight g</td>
            </tr>
            <tr>
                <td>Percentage water content of diet:</td>
                <td>@data.DietWaterPercentage %</td>
            </tr>
            <tr>
                <td>Number of days to increase food intake over:</td>
                <td>@data.Days</td>
            </tr>
        </table>
    }

</div>

@code {
    PatientDietData data = new();
    List<Volumes> CalculatedVolumes = [];
    bool calculated = false;
    int newBodyWeight;
    bool newSpecies = true;
    int newDays;
    string newPatientName = "";
    string newDietName = "";
    double newKcalPerG;
    double newDietNetWeight;
    double newDietWaterPercentage;

    private void Calculate()
    {
        data = new()
        { 
            BodyWeight = newBodyWeight,
            Species = newSpecies,
            Days = newDays,
            PatientName = newPatientName,
            DietName = newDietName,
            KcalPerG = newKcalPerG,
            DietNetWeight = newDietNetWeight,
            DietWaterPercentage = newDietWaterPercentage
        };

        @for (int day = 1; day < data.Days + 1; day++)
        {
            Volumes volumes = new(data);
            volumes.Calculate(day);
            CalculatedVolumes.Add(volumes);
        }

        calculated = true;
    }

    private void Reset()
    {
        calculated = false;
        data = new();
    }
}