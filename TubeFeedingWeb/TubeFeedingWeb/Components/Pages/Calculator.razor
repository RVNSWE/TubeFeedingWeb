@page "/calculator"
@rendermode InteractiveAuto

<PageTitle>Calculator</PageTitle>

<div class="main">

    @if (calculated == false)
    {
        <h3>Calculate Feeding Volumes</h3>

        <div>
            <form>
                <ul>
                    <li><label>Patient name:<input @bind=data.PatientName></input></label></li>
                    <li>
                        <label>Species:
                                @foreach (string species in speciesSelection)
                                {
                                    <label>@species<radio Name="species" value="@species"></radio></label>
                                }
                        </label>
                    </li>
                    <li><label>Body weight:<input @bind="data.BodyWeight" min="0" max="200"></input></label>kg</li>
                    <li><label>Name of diet to be fed:<input @bind=data.DietName></input></label></li>
                    <li><label>Kcal per gram:<input @bind=data.KcalPerG min="0" max="10"></input></label></li>
                    <li><label>Net weight per container (g or ml):<input @bind=data.DietNetWeight min="0" max="1000"></input></label></li>
                    <li><label>Moisture content (%):<input @bind=data.DietWaterPercentage min="0" max="100"></input></label></li>
                    <li><label>Number of days to re-feed over (enter "1" if starting at full RER):<input @bind=data.Days min="1" max="10"></input></label></li>
                    <li><input type="submit" value="Calculate" disabled=@calculating /></li>
                </ul>
            </form>
        </div>

        @* <div>
            <EditForm Model="data" OnSubmit="ProcessData">
                <ul>
                    <li><label>Patient name:<InputText @bind-Value=data.PatientName></InputText></label></li>
                    <li><ValidationMessage For="@(() => data.PatientName)" /></li>
